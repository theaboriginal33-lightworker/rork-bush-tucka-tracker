{
  "expo": {
    "name": "Bush Tucka Tracker",
    "slug": "bush-tucka-tracka",
    "version": "3.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rork-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "buildNumber": "13",
      "bundleIdentifier": "app.rork.bush-tucka-tracker",
      "icon": "./assets/images/icon.png",
      "config": {
        "googleMapsApiKey": "AIzaSyAFrrz5XvKH9nBbIIAyIlLCil0azTKYwA8"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to show plant sightings near you.",
        "NSLocationAlwaysUsageDescription": "We need your location to show plant sightings near you."
      },
      "appleTeamId": "542P4J57LM",
      "splash": {
        "image": "./assets/images/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#000000"
      }
    },
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "app.rork.bush_tucka_tracker",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAFrrz5XvKH9nBbIIAyIlLCil0azTKYwA8"
        }
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "splash": {
        "image": "./assets/images/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#000000"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Bush Tucka Tracker to use your location to show nearby plant sightings."
        }
      ],
      "./plugins/withReactNativeMaps",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Bush Tucka Tracker to choose photos to scan plants and set recipe images.",
          "cameraPermission": "Allow Bush Tucka Tracker to take photos for plant scanning."
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": "https://rork.com/"
      },
      "eas": {
        "projectId": "30746df5-2087-42aa-81da-f27a6d755195"
      }
    },
    "owner": "evish3652"
  }
}
